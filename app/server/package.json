{
      "name": "delicakes-app",
      "version": "1.0.0",
      "description": "Delicakes Node.js application",
      "main": "dist/server.js",
      "scripts": {
            "build": "tsc -p tsconfig.json",
            "start": "node dist/server.js",
            "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/server.js\"",

            "app:dev": "PORT=3000 npm run dev",
            "api:dev": "PORT=3100 npm --prefix ../../api run dev",
            "mainui:build": "npm --prefix ../UI/mainUI run build",
            "mainui:watch": "npm --prefix ../UI/mainUI run watch",
            "expense-tracker:build": "npm --prefix ../UI/expense-tracker run build",
            "expense-tracker:watch": "npm --prefix ../UI/expense-tracker run watch"
            ,
            "win:mainui:build": "npm --prefix ..\\UI\\mainUI run win:build",
            "win:expense-tracker:build": "npm --prefix ..\\UI\\expense-tracker run win:build"
      },
      "keywords": [],
      "author": "",
      "license": "ISC",
      "dependencies": {
            "cookie-parser": "^1.4.7",
            "dotenv": "^17.3.1",
            "express": "^4.18.2",
            "pg": "^8.18.0"
      },
      "devDependencies": {
            "@types/cookie-parser": "^1.4.9",
            "@types/express": "^4.17.23",
            "@types/node": "^22.13.5",
            "@types/pg": "^8.15.5",
            "nodemon": "^3.0.1",
            "typescript": "^5.9.3"
      }
}
