      },
      "devDependencies": {
            "@eslint/js": "^9.39.4",
            "@types/cors": "^2.8.18",
            "@types/express": "^4.17.23",
            "@types/node": "^22.13.5",
            "@types/pg": "^8.16.0",
            "@typescript-eslint/eslint-plugin": "^8.58.2",
            "@typescript-eslint/parser": "^8.58.2",
            "eslint": "^9.39.4",
            "eslint-config-prettier": "^10.1.8",
            "nodemon": "^3.1.11",
